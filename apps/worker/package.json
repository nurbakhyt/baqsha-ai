{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply baqsha-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply baqsha-db --local",
    "db:seed": "wrangler d1 execute baqsha-db --remote --file=./seeds.sql",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@copilotkit/runtime": "^1.0.0",
    "hono": "^4.5.0",
    "jose": "^5.6.0",
    "zod": "^3.23.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241200.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.100.0"
  }
}