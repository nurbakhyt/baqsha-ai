{
  "name": "baqsha-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "deploy:worker": "turbo run deploy --filter=worker",
    "deploy:web": "turbo run deploy --filter=web",
    "db:migrate": "turbo run db:migrate --filter=worker",
