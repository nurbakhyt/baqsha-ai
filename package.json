    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.100.0"
  },
  "packageManager": "pnpm@9.0.0"
}